class Solution {
    public boolean isPerfectSquare(int num) {
        if(num < 1) return false;
        if(num == 1) return true;

        long left = 1;
        long right = num;
        while(left <= right){
            long mid = left + (right - left)/2;
            long ans = mid*mid;
            if(ans > num){
                right = mid - 1;
            }
            else if(ans < num){
                left = mid + 1;
            }
            else{
                return true;
            }
        }
        return false;
    }

}
