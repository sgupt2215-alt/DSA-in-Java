class Solution {
    public int[] twoSum(int[] numbers, int target) {
       int start = 0;
       int end = numbers.length - 1;
       while(start<end){
        int currentsum = numbers[start] + numbers[end];
        if(currentsum < target){
            start++;
         }
        else if(currentsum> target){
            end --;
        }
        else{
          
           return new int[]{start + 1 , end + 1};
        }
       }
       return new int[]{-1,-1};
    }
}

